# Signaling server URL for WebRTC
VITE_SIGNALING_URL=ws://localhost:3001

# TURN server (optional, for NAT traversal)
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# API base URL (when backend is ready)
VITE_API_BASE_URL=http://localhost:8080/api

# API request timeout in milliseconds (default: 10000)
VITE_API_TIMEOUT=10000

# CDN base URL for static assets and images (EN-11, EN-17)
VITE_CDN_BASE_URL=

# App environment
VITE_APP_ENV=development